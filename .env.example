# Plant3D-Web 环境配置示例
# 复制此文件为 .env.development 或 .env.production 并填入实际值

# SurrealDB 数据库连接配置
# WebSocket URL（Surreal 2.x 常用 /rpc 后缀；端口与服务器 surreal 监听一致）
# 本地示例: ws://localhost:8020/rpc
# 生产: 见 plant-model-gen/shells/run_surrealdb_kv_8020.sh（默认 8020）
VITE_SURREAL_URL=ws://localhost:8020/rpc
# 命名空间
VITE_SURREAL_NS=1516
# 数据库名
VITE_SURREAL_DB=AvevaMarineSample
# 用户名
VITE_SURREAL_USER=root
# 密码
VITE_SURREAL_PASS=root
