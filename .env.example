# Plant3D-Web 环境配置示例
# 复制此文件为 .env.development 或 .env.production 并填入实际值

# SurrealDB 数据库连接配置
# WebSocket URL (本地: ws://localhost:8020, 生产: ws://123.57.182.243:8020)
VITE_SURREAL_URL=ws://localhost:8020
# 命名空间
VITE_SURREAL_NS=1516
# 数据库名
VITE_SURREAL_DB=AvevaMarineSample
# 用户名
VITE_SURREAL_USER=root
# 密码
VITE_SURREAL_PASS=root
