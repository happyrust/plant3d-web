                        { "type": "text", "id": "slSlopeFormatLabel", "name": "slopeFormatLabel", "fill": "#6B7280", "content": "坡度格式", "fontFamily": "Fira Sans", "fontSize": 12, "fontWeight": "500" },
                        {
                          "type": "frame",
                          "id": "slSlopeFormatSelect",
