                          "padding": [8, 12],
                          "justifyContent": "space_between",
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "slSlopeFormatVal", "name": "slopeFormatVal", "fill": "#111827", "content": "角度 (Angle)", "fontFamily": "Fira Sans", "fontSize": 13, "fontWeight": "normal" },
                            { "type": "icon_font", "id": "slSlopeFormatChevron", "name": "chevron", "width": 14, "height": 14, "iconFontName": "chevron-down", "iconFontFamily": "lucide", "fill": "#9CA3AF" }
                          ]
