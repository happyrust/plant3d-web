{
  "version": "2.8",
  "children": [
    {
      "type": "frame",
      "id": "canvas4",
      "x": 0,
      "y": 0,
      "name": "Frame",
      "clip": true,
      "width": 800,
      "height": 1100,
      "fill": "#FFFFFF",
      "layout": "none"
    },
    {
      "type": "frame",
      "id": "slRoot",
      "x": 0,
      "y": 0,
      "name": "管道坡度面板",
      "width": 360,
      "fill": "#FFFFFF",
      "cornerRadius": 8,
      "stroke": {
        "align": "inside",
        "thickness": 1,
        "fill": "#E5E7EB"
      },
      "effect": {
        "type": "shadow",
        "shadowType": "outer",
        "color": "#0000000f",
        "offset": { "x": 0, "y": 4 },
        "blur": 16
      },
      "layout": "vertical",
      "gap": 0,
      "padding": 0,
      "children": [
        {
          "type": "frame",
          "id": "slHeader",
          "name": "header",
          "width": "fill_container",
          "fill": "#FAFAFA",
          "padding": [16, 20],
          "justifyContent": "space_between",
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "slTitle",
              "name": "title",
              "fill": "#111827",
              "content": "管道坡度",
              "fontFamily": "Fira Sans",
              "fontSize": 16,
              "fontWeight": "600"
            },
            {
              "type": "frame",
              "id": "slUndoRedoGroup",
              "name": "undoRedoGroup",
              "gap": 4,
              "children": [
                {
                  "type": "frame",
                  "id": "slUndoBtn",
                  "name": "undoBtn",
                  "width": 32,
                  "height": 32,
                  "fill": "#00000000",
                  "cornerRadius": 6,
                  "stroke": { "align": "inside", "thickness": 1, "fill": "#E5E7EB" },
                  "justifyContent": "center",
                  "alignItems": "center",
                  "children": [
                    { "type": "icon_font", "id": "slUndoIcon", "name": "undoIcon", "width": 14, "height": 14, "iconFontName": "undo-2", "iconFontFamily": "lucide", "fill": "#6B7280" }
                  ]
                },
                {
                  "type": "frame",
                  "id": "slRedoBtn",
                  "name": "redoBtn",
                  "width": 32,
                  "height": 32,
                  "fill": "#00000000",
                  "cornerRadius": 6,
                  "stroke": { "align": "inside", "thickness": 1, "fill": "#E5E7EB" },
                  "justifyContent": "center",
                  "alignItems": "center",
                  "children": [
                    { "type": "icon_font", "id": "slRedoIcon", "name": "redoIcon", "width": 14, "height": 14, "iconFontName": "redo-2", "iconFontFamily": "lucide", "fill": "#6B7280" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "line",
          "id": "slDivH",
          "name": "dividerHeader",
          "width": "fill_container",
          "height": 1,
          "stroke": { "align": "center", "thickness": 1, "fill": "#E5E7EB" }
        },
        {
          "type": "frame",
          "id": "slInfoBar",
          "name": "infoBar",
          "width": "fill_container",
          "fill": "#F9FAFB",
          "padding": [10, 20],
          "gap": 16,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "slInfoPipe",
              "name": "infoPipe",
              "gap": 6,
              "alignItems": "center",
