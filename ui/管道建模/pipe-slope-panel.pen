                        { "type": "text", "id": "slAnchor2Type", "name": "anchor2Type", "width": 80, "fill": "#374151", "content": "Floating", "fontFamily": "Fira Sans", "fontSize": 11, "fontWeight": "normal" },
                        { "type": "text", "id": "slAnchor2Comp", "name": "anchor2Comp", "width": 100, "fill": "#6B7280", "content": "TEE /B1-T2", "fontFamily": "Fira Code", "fontSize": 11, "fontWeight": "normal" },
                        { "type": "text", "id": "slAnchor2Dist", "name": "anchor2Dist", "width": 70, "fill": "#6B7280", "content": "1800 mm", "fontFamily": "Fira Code", "fontSize": 11, "fontWeight": "normal" },
                        { "type": "text", "id": "slAnchor2Offset", "name": "anchor2Offset", "width": 60, "fill": "#6B7280", "content": "0 mm", "fontFamily": "Fira Code", "fontSize": 11, "fontWeight": "normal" }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "slApplyBtn",
              "name": "applyBtn",
              "width": "fill_container",
              "fill": "#FF6B00",
              "cornerRadius": 6,
              "gap": 8,
              "padding": [10, 16],
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "icon_font", "id": "slApplyIcon", "name": "applyIcon", "width": 14, "height": 14, "iconFontName": "check", "iconFontFamily": "lucide", "fill": "#FFFFFF" },
                { "type": "text", "id": "slApplyText", "name": "applyText", "fill": "#FFFFFF", "content": "应用坡度", "fontFamily": "Fira Sans", "fontSize": 14, "fontWeight": "500" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
